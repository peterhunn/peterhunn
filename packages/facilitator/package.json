{
  "name": "@x490/facilitator",
  "version": "0.1.0",
  "description": "Hosted x490 facilitator — managed token issuance, template registry, and agreement tracking for the x490 protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "x490-facilitator": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "migrate": "tsx src/migrate.ts",
    "test": "node --import tsx/esm --test 'src/__tests__/*.test.ts'"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@x490/core": "*",
    "@x490/protocol": "*",
    "hono": "^4.4.0",
    "jose": "^5.0.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.0.0",
    "postgres": "^3.4.0",
    "viem": "^2.21.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
